<?xml version="1.0" encoding="utf-8"?>
<root>
  <xsd:schema id="root" xmlns="" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:msdata="urn:schemas-microsoft-com:xml-msdata">
    <xsd:element name="root" msdata:IsDataSet="true">
      <xsd:complexType>
        <xsd:choice maxOccurs="unbounded">
          <xsd:element name="data">
            <xsd:complexType>
              <xsd:sequence>
                <xsd:element name="value" type="xsd:string" minOccurs="0" msdata:Ordinal="1" />
                <xsd:element name="comment" type="xsd:string" minOccurs="0" msdata:Ordinal="2" />
              </xsd:sequence>
              <xsd:attribute name="name" type="xsd:string" msdata:Ordinal="0" />
            </xsd:complexType>
          </xsd:element>
          <xsd:element name="resheader">
            <xsd:complexType>
              <xsd:sequence>
                <xsd:element name="value" type="xsd:string" minOccurs="0" msdata:Ordinal="1" />
              </xsd:sequence>
              <xsd:attribute name="name" type="xsd:string" use="required" />
            </xsd:complexType>
          </xsd:element>
        </xsd:choice>
      </xsd:complexType>
    </xsd:element>
  </xsd:schema>
  <resheader name="resmimetype"><value>text/microsoft-resx</value></resheader>
  <resheader name="version"><value>2.0</value></resheader>
  <resheader name="reader"><value>System.Resources.ResXResourceReader</value></resheader>
  <resheader name="writer"><value>System.Resources.ResXResourceWriter</value></resheader>

  <!-- Header -->
  <data name="AppTitle" xml:space="preserve"><value>🛒 Shopping Assistant</value></data>
  <data name="ExtensionConnected" xml:space="preserve"><value>🔗 Extension connected</value></data>
  <data name="ExtensionNotConnected" xml:space="preserve"><value>⚠️ Extension not connected</value></data>
  <data name="LlmReady" xml:space="preserve"><value>🤖 LLM ready</value></data>
  <data name="LlmNotReachable" xml:space="preserve"><value>⚠️ LLM not reachable</value></data>

  <!-- Welcome -->
  <data name="WelcomeMessage" xml:space="preserve"><value>👋 Welcome! Give me your ingredient list and I'll fill your shopping cart.</value></data>
  <data name="WelcomeHint" xml:space="preserve"><value>Example: "3 packs of toast, 1 small butter, 500g carrots"</value></data>

  <!-- Input -->
  <data name="InputPlaceholder" xml:space="preserve"><value>Enter ingredient list or type a message...</value></data>

  <!-- Agent messages -->
  <data name="LlmError" xml:space="preserve"><value>⚠️ LLM error: {0}</value></data>
  <data name="LlmTimeout" xml:space="preserve"><value>⏱️ LLM request timed out after 60 seconds. Please try again.</value></data>
  <data name="ToolCall" xml:space="preserve"><value>🔧 Tool: {0}({1})...</value></data>
  <data name="ToolResult" xml:space="preserve"><value>✅ Result: {0}</value></data>
  <data name="ProductAddedToCart" xml:space="preserve"><value>Product successfully added to cart.</value></data>
  <data name="ErrorAddingToCart" xml:space="preserve"><value>Error adding product to cart.</value></data>
  <data name="UnknownTool" xml:space="preserve"><value>Unknown tool: {0}</value></data>
  <data name="ToolError" xml:space="preserve"><value>Tool error: {0}</value></data>
  <data name="RepeatedToolFailure" xml:space="preserve"><value>Tool "{0}" failed 3 times in a row. Stopping to prevent an infinite loop.</value></data>
  <data name="PreferenceSaved" xml:space="preserve"><value>Preference saved for future shopping sessions.</value></data>
  <data name="PreferenceDeleted" xml:space="preserve"><value>Preference deleted.</value></data>
  <data name="PreferenceNotFound" xml:space="preserve"><value>Preference not found.</value></data>
  <data name="ToolCallingFallback" xml:space="preserve"><value>⚠️ This model does not support tool-calling. Switching to text-only mode — I'll give instructions, but cannot control the browser directly.</value></data>

  <!-- Extension bridge -->
  <data name="ExtensionNotConnectedError" xml:space="preserve"><value>Chrome extension is not connected. Please install the extension and reload the page.</value></data>
  <data name="ToolCallTimeout" xml:space="preserve"><value>Tool call timed out after 30 seconds.</value></data>
  <data name="EmptyExtensionResponse" xml:space="preserve"><value>Empty response from extension.</value></data>
  <data name="ParseError" xml:space="preserve"><value>Parse error: {0}</value></data>

  <!-- Preferences -->
  <data name="LearnedPreferences" xml:space="preserve"><value>Learned preferences:</value></data>

  <!-- Chat UI -->
  <data name="ClearChat" xml:space="preserve"><value>Clear</value></data>
  <data name="CopyChat" xml:space="preserve"><value>Copy chat</value></data>
  <data name="StopProcessing" xml:space="preserve"><value>Stop</value></data>
  <data name="ProcessingStopped" xml:space="preserve"><value>Processing stopped.</value></data>
  <data name="LoadFromMealPlan" xml:space="preserve"><value>Load from meal plan</value></data>
  <data name="NoIngredientsFound" xml:space="preserve"><value>No ingredients found in the meal plan. Please create meals first.</value></data>

  <!-- API Key -->
  <data name="ApiKeyPrompt" xml:space="preserve"><value>Enter your Mistral API key to start. The key is only stored in memory and never saved to disk or browser storage.</value></data>
  <data name="ApiKeySubmit" xml:space="preserve"><value>Connect</value></data>
  <data name="ApiKeyCancel" xml:space="preserve"><value>Cancel</value></data>
  <data name="ApiKeyValidating" xml:space="preserve"><value>Validating...</value></data>
  <data name="ApiKeyInvalid" xml:space="preserve"><value>Invalid API key. Please check and try again.</value></data>

  <!-- Navigation -->
  <data name="TabTitle" xml:space="preserve"><value>Shopping Assistant</value></data>
</root>
