{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore.DataProtection": "Error",
      "Microsoft.AspNetCore.Antiforgery": "None",
      // not relevant for this app as it contains no secrets, i.e. it's safe to ignore the runtime warnings during startup
      "Microsoft.Hosting.Lifetime": "Information"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "TimestampFormat": "yyyy-MM-dd HH:mm:ss.FFFK "
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "SQLite": "Data Source=/home/app/db/ShopAndEat.db"
  },
  "LlmClient": {
    "Endpoint": "https://api.mistral.ai/v1",
    "DefaultModel": "mistral-small-latest",
    "TimeoutSeconds": 60
  },
  "Agent": {
    "MaxToolCallingIterations": 50,
    "ToolFailureThreshold": 3
  },
  "Extension": {
    "ToolCallTimeoutSeconds": 30
  },
  "Shops": {
    "Shops": [
      {
        "Key": "coop",
        "Name": "Coop",
        "BaseUrl": "https://www.coop.ch",
        "CartUrl": "https://www.coop.ch/de/cart"
      }
    ]
  }
}
