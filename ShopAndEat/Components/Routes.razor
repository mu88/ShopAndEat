<Router AppAssembly="@typeof(Program).Assembly" AdditionalAssemblies="new[] { typeof(ShoppingAgent.Pages.Home).Assembly }" NotFoundPage="@typeof(Pages.NotFound)">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)"/>
        <FocusOnNavigate RouteData="@routeData" Selector="h1"/>
    </Found>
</Router>
